{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" },
    { "name": "DS_LOKI",       "label": "Loki",       "type": "datasource", "pluginId": "loki" }
  ],
  "title": "Kiruz Platform Overview",
  "uid":   "kiruz-overview",
  "tags":  ["kiruz", "overview"],
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (RPS) — all services",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{
        "expr": "sum(rate(http_requests_total[2m])) by (job)",
        "legendFormat": "{{ job }}"
      }]
    },
    {
      "id": 2,
      "title": "Error Rate (5xx %)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{
        "expr": "sum(rate(http_requests_total{status=~\"5..\"}[2m])) by (job) / sum(rate(http_requests_total[2m])) by (job) * 100",
        "legendFormat": "{{ job }} error%"
      }]
    },
    {
      "id": 3,
      "title": "P50 / P95 / P99 Latency — Saleor",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"saleor\"}[2m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"saleor\"}[2m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"saleor\"}[2m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 4,
      "title": "Active Pods per Namespace",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{
        "expr": "count(kube_pod_status_ready{condition=\"true\"}) by (namespace)",
        "legendFormat": "{{ namespace }}"
      }]
    },
    {
      "id": 5,
      "title": "Cluster CPU Usage (%)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{
        "expr": "100 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "thresholds": { "steps": [{"value": 0, "color": "green"}, {"value": 70, "color": "yellow"}, {"value": 90, "color": "red"}] } } }
    },
    {
      "id": 6,
      "title": "Cluster Memory Usage (%)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{
        "expr": "(1 - avg(node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "thresholds": { "steps": [{"value": 0, "color": "green"}, {"value": 75, "color": "yellow"}, {"value": 90, "color": "red"}] } } }
    },
    {
      "id": 7,
      "title": "ArgoCD Application Health",
      "type": "table",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{
        "expr": "argocd_app_info",
        "legendFormat": "{{ name }}"
      }]
    }
  ]
}
